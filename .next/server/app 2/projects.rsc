c:["$","div","Europe's AI Regulation Problem",{"children":[["$","div",null,{"className":"py-10","children":[["$","p",null,{"className":"text-label uppercase tracking-widest text-ink-muted italic mb-3","children":"Advanced Macroeconomics · AUC · May 2026"}],["$","h2",null,{"className":"text-base font-medium text-ink mb-4","children":"Europe's AI Regulation Problem"}],["$","p",null,{"className":"text-base text-ink-muted leading-relaxed mb-6","children":"An essay arguing that the EU AI Act's compliance costs aren't well calibrated to firm size, and that this has macroeconomic consequences the policy debate mostly ignores. I worked through the Solow growth model, the government budget constraint, and the Taylor Rule to show how regulatory drag on AI adoption affects productivity and fiscal sustainability. There's a note at the end where I try to fix an argument the professor challenged during the presentation."}],["$","a",null,{"href":"/projects/eu-ai-regulation.pdf","target":"_blank","rel":"noopener noreferrer","className":"group inline-flex items-center text-small text-ink-muted transition-opacity duration-150 hover:opacity-60","children":["Download PDF",["$","span",null,{"className":"transition-transform duration-150 group-hover:translate-x-0.75","children":" →"}]]}]]}],["$","div",null,{"className":"border-t border-line"}]]}]
d:["$","div","Global Data Privacy Regulations and Machine Learning",{"children":[["$","div",null,{"className":"py-10","children":[["$","p",null,{"className":"text-label uppercase tracking-widest text-ink-muted italic mb-3","children":"Data Ethics · AUC"}],["$","h2",null,{"className":"text-base font-medium text-ink mb-4","children":"Global Data Privacy Regulations and Machine Learning"}],["$","p",null,{"className":"text-base text-ink-muted leading-relaxed mb-6","children":"A report on how GDPR, CCPA, and China's PIPL affect the way machine learning systems get built. I started with the Meta fine as an entry point — a billion-euro penalty for what was essentially a routine engineering decision — and traced how these frameworks developed and what they actually require of developers in practice. The consent section compares how differently the three frameworks approach the same problem."}],["$","a",null,{"href":"/projects/data-ethics-report.pdf","target":"_blank","rel":"noopener noreferrer","className":"group inline-flex items-center text-small text-ink-muted transition-opacity duration-150 hover:opacity-60","children":["Download PDF",["$","span",null,{"className":"transition-transform duration-150 group-hover:translate-x-0.75","children":" →"}]]}]]}],["$","div",null,{"className":"border-t border-line"}]]}]
e:["$","div","GPU Demand Growth and Semiconductor Shortages",{"children":[["$","div",null,{"className":"py-10","children":[["$","p",null,{"className":"text-label uppercase tracking-widest text-ink-muted italic mb-3","children":"Mathematical Methods · AUC"}],["$","h2",null,{"className":"text-base font-medium text-ink mb-4","children":"GPU Demand Growth and Semiconductor Shortages"}],["$","p",null,{"className":"text-base text-ink-muted leading-relaxed mb-6","children":"A group project modeling NVIDIA's revenue growth using exponential functions and analyzing the semiconductor shortage during COVID-19. More quantitative than the others — we modeled demand curves, calculated growth rates, and built a forecast error model to show how badly the industry misjudged demand. A bit rougher, but it shows the kind of applied mathematics from the first year."}],["$","a",null,{"href":"/projects/gpu-semiconductors.pdf","target":"_blank","rel":"noopener noreferrer","className":"group inline-flex items-center text-small text-ink-muted transition-opacity duration-150 hover:opacity-60","children":["Download PDF",["$","span",null,{"className":"transition-transform duration-150 group-hover:translate-x-0.75","children":" →"}]]}]]}],false]}]
