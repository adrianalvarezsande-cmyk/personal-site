a:["$","a",null,{"href":"/projects/algorithmic-collusion.pdf","target":"_blank","rel":"noopener noreferrer","className":"group inline-flex items-center text-small text-ink-muted transition-opacity duration-150 hover:opacity-60","children":["Download PDF",["$","span",null,{"className":"transition-transform duration-150 group-hover:translate-x-0.75","children":" →"}]]}]
